# ─── Tasheen Storefront — Local Environment ─────────────────────────────────
# Copy to `.env.local` and fill in real values.

# Public — exposed to the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_BRAND=Tasheen

# Auth (NextAuth.js if used; otherwise consumed by AuthProvider)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-in-production

# Stripe / payment provider public keys (the secret keys live ONLY in the API)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Image CDN
NEXT_PUBLIC_IMAGE_CDN=

# Firebase — public web SDK config (browser-safe; not secrets)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
